---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogoCloud from "../components/LogoCloud.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import GoogleReviews from "../components/GoogleReviews.astro";
import CTASection from "../components/CTASection.astro";
import Testimonials from "../components/Testimonials.astro";
import Stats from "../components/Stats.astro";
import { contact, site, partners } from "../data/site";
import { caseStudies } from "../data/caseStudies";

// Chiffres clés — uniquement des données réelles / vérifiables.
// (Le nombre d'événements organisés n'est pas confirmé : volontairement non affiché.)
const anneesExpertise = new Date().getFullYear() - site.foundedYear;
const homeStats = [
  { value: `${anneesExpertise} ans`, label: "d'expertise, depuis 2006" },
  { value: "24-48 h", label: "pour recevoir votre shortlist" },
  { value: "0 €", label: "de frais pour votre entreprise" },
  { value: `${partners.length}+`, label: "partenaires sélectionnés" },
];

const title =
  "Euro Events — Maison de curation événementielle à Paris | Sélection gratuite de prestataires";
const description = site.description;

const heroSlides = [
  { src: "/images/hero/1.jpg", alt: "Château de Chambord, lieu d'exception", place: "Château de Chambord", meta: "Val de Loire" },
  { src: "/images/hero/2.jpg", alt: "Dîner de gala, scénographie florale", place: "Dîner de gala", meta: "Scénographie sur mesure" },
  { src: "/images/hero/3.jpg", alt: "Lieu événementiel contemporain vitré", place: "Lieu contemporain", meta: "Convention & soirée" },
  { src: "/images/hero/4.jpg", alt: "Salle de réception dressée", place: "Banquet & réception", meta: "Dîner assis" },
];

const procede = [
  { n: "01", t: "Vous nous confiez votre projet", d: "Type d'événement, convives, dates, lieu, budget. En quelques minutes, par téléphone ou en ligne." },
  { n: "02", t: "Notre experte compose la sélection", d: "Elle recherche, compare et négocie à la main les lieux et prestataires qui servent vos objectifs." },
  { n: "03", t: "Vous recevez votre shortlist", d: "Une sélection argumentée et des devis, sous 24 à 48 h. Vous choisissez ; nous orchestrons jusqu'au jour J." },
];

const univers = [
  {
    sel: "SÉL. 01",
    title: "Séminaires & conventions",
    text: "Des châteaux de la Loire aux rooftops parisiens : lieux résidentiels, plénières, hébergement, technique et animations. Nous composons le cadre, vous portez le message.",
    cta: "Voir les séminaires",
    href: "/nos-evenements/seminaires-entreprise/",
    img: "/images/events/seminaire.jpg",
    alt: "Séminaire d'entreprise en salle à boiseries et lustre en cristal",
  },
  {
    sel: "SÉL. 02",
    title: "Soirées & team building",
    text: "Dîners de gala, fêtes de fin d'année, défis outdoor, ateliers de cohésion. Le lieu, le traiteur, l'animation et la décoration, sélectionnés pour faire date.",
    cta: "Voir les soirées",
    href: "/nos-evenements/soirees-entreprise/",
    img: "/images/events/soiree.jpg",
    alt: "Dîner de gala d'entreprise",
  },
  {
    sel: "SÉL. 03",
    title: "Lieux & prestataires",
    text: "Vingt ans de carnet d'adresses : hôteliers, traiteurs, transferts, scénographes, hôtes et hôtesses. Une curation négociée, sans frais ni dépassement.",
    cta: "Découvrir le réseau",
    href: "/partenaires/",
    img: "/images/gallery/reception.jpg",
    alt: "Réception d'exception dans un lieu d'exception",
  },
];

const atouts = [
  ["Gratuit pour votre entreprise", "Aucun honoraire, aucune commission à votre charge. Notre rémunération vient des prestataires."],
  ["Une interlocutrice, pas un standard", "La même experte du premier échange au jour J. Une relation, pas un ticket."],
  ["Une réponse sous 24-48 h", "Le temps d'une vraie curation, jamais l'attente d'un devis classique."],
  ["Votre budget tenu", "Nous partons de votre enveloppe et négocions pour vous. Pas de dépassement, pas de surprise."],
];

const galerie = [
  { src: "/images/hero/1.jpg", alt: "Château de Chambord" },
  { src: "/images/events/soiree.jpg", alt: "Dîner de gala" },
  { src: "/images/events/convention.jpg", alt: "Auditorium contemporain à boiseries" },
  { src: "/images/gallery/reception.jpg", alt: "Réception privée" },
  { src: "/images/events/teambuilding.jpg", alt: "Team building et banquet en cave voûtée" },
  { src: "/images/gallery/sommet.jpg", alt: "Plénière de convention, scène éclairée en bleu" },
];
---

<BaseLayout title={title} description={description} path="/" transparentHeader>
  <!-- ====================== HERO PLEIN CADRE ====================== -->
  <section class="hero-full" aria-label="Euro Events, maison de curation événementielle">
    <div class="hero-bg" id="hero-carousel">
      {
        heroSlides.map((s, i) => (
          <img
            class:list={["hero-slide", { "is-active": i === 0 }]}
            src={s.src}
            alt={s.alt}
            data-place={s.place}
            data-meta={s.meta}
            data-sel={`SÉL. 0${i + 1}`}
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : undefined}
            decoding="async"
          />
        ))
      }
      <div class="hero-scrim"></div>
    </div>

    <span class="hero-tab" id="hero-tab">SÉL. 01</span>

    <div class="container hero-content">
      <p class="hero-eyebrow">Maison de curation · Paris · depuis 2006</p>
      <h1 class="hero-title">
        <span class="hl-line"><span>Une sélection</span></span>
        <span class="hl-line"><span>faite à la main,</span></span>
        <span class="hl-line"><span class="hl-accent">pas par un moteur.</span></span>
      </h1>
      <div class="btn-row hero-actions">
        <a href="/devis/" class="btn btn--accent btn--lg">Demander ma sélection gratuite</a>
        <a href={`tel:${contact.phoneHref}`} class="btn btn--ghostlight btn--lg">{contact.phoneDisplay}</a>
      </div>
    </div>

    <figcaption class="hero-legend">
      <span class="hl-place" id="hero-place">Château de Chambord</span>
      <span class="hl-meta" id="hero-meta">Val de Loire</span>
    </figcaption>

    <a href="#manifeste" class="hero-scroll" aria-label="Faire défiler">
      <span>Découvrir</span>
      <span class="hero-scroll-line"></span>
    </a>
  </section>

  <!-- ====================== MANIFESTE ====================== -->
  <section class="section manifeste" id="manifeste">
    <div class="container manifeste-inner">
      <span class="manifeste-watermark" aria-hidden="true">2006</span>
      <p class="eyebrow reveal">Le métier</p>
      <p class="manifeste-text reveal">
        Nous <strong>dénichons</strong> les lieux. <strong>Négocions</strong> les prestataires.
        <strong>Orchestrons</strong> chaque détail. Depuis vingt ans, une experte sélectionne
        pour vous — <span class="hl-accent">à la main, et gratuitement.</span>
      </p>
    </div>
  </section>

  <!-- ====================== PROCÉDÉ ====================== -->
  <section class="section bg-cream procede">
    <div class="container">
      <div class="procede-head reveal">
        <p class="eyebrow">Le procédé</p>
        <h2>Trois temps, une seule interlocutrice.</h2>
      </div>
      <ol class="timeline">
        {procede.map((s) => (
          <li class="tl-item reveal">
            <span class="tl-num">{s.n}</span>
            <div class="tl-body"><h3>{s.t}</h3><p>{s.d}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ====================== UNIVERS (blocs alternés, image full-bleed) ====================== -->
  <section class="section univers">
    <div class="container">
      <div class="univers-head reveal">
        <p class="eyebrow">Nos univers</p>
        <h2>Ce que nous composons pour vous.</h2>
      </div>
    </div>
    <div class="univers-list">
      {
        univers.map((u, i) => (
          <article class:list={["univers-row reveal", { "is-reverse": i % 2 === 1 }]}>
            <a href={u.href} class="univers-media">
              <img src={u.img} alt={u.alt} loading="lazy" decoding="async" />
            </a>
            <div class="univers-body">
              <span class="univers-sel">{u.sel}</span>
              <h3>{u.title}</h3>
              <p>{u.text}</p>
              <a href={u.href} class="link-arrow">{u.cta}</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <LogoCloud title="Une sélection éprouvée par les entreprises exigeantes" />

  <!-- ====================== POURQUOI ÇA MARCHE ====================== -->
  <section class="section bg-navy approche">
    <div class="container approche-grid">
      <div class="approche-intro reveal">
        <p class="eyebrow">Pourquoi nous</p>
        <h2>Une maison, pas une plateforme.</h2>
        <p class="lead">
          Nous ne renvoyons pas une liste générée. Nous engageons une personne, un goût,
          vingt ans de carnet d'adresses — au service d'un seul projet : le vôtre.
        </p>
        <a href="/notre-concept/" class="btn btn--outline">Notre façon de travailler</a>
      </div>
      <dl class="atouts">
        {atouts.map((a, i) => (
          <div class="atout reveal">
            <dt><span class="atout-num">{String(i + 1).padStart(2, "0")}</span>{a[0]}</dt>
            <dd>{a[1]}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ====================== APERÇU GALERIE ====================== -->
  <section class="section galerie-preview">
    <div class="container">
      <div class="shortlist-head reveal">
        <div>
          <p class="eyebrow">La galerie</p>
          <h2>Lieux & moments d'exception.</h2>
        </div>
        <a href="/galerie/" class="btn btn--outline">Voir la galerie complète</a>
      </div>
      <div class="gp-grid">
        {galerie.map((g) => (
          <a href="/galerie/" class="gp-item reveal">
            <img src={g.src} alt={g.alt} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================== RÉFÉRENCES DATÉES ====================== -->
  <section class="section bg-cream">
    <div class="container">
      <div class="shortlist-head reveal">
        <div>
          <p class="eyebrow">Au dossier</p>
          <h2>Quelques événements signés Euro Events.</h2>
        </div>
        <a href="/references/" class="btn btn--outline">Toutes les références</a>
      </div>
      <div class="grid grid-3">
        {caseStudies.map((study, i) => <CaseStudyCard study={study} sel={`SÉL. 0${i + 1}`} />)}
      </div>
    </div>
  </section>

  <!-- ====================== CHIFFRES CLÉS (réassurance) ====================== -->
  <Stats items={homeStats} />

  <Testimonials />

  <GoogleReviews />

  <CTASection />
</BaseLayout>

<style>
  /* ========== HERO PLEIN CADRE ========== */
  .hero-full {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-encre);
    color: #fff;
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-slide {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; opacity: 0; transition: opacity 1.1s var(--ease);
  }
  .hero-slide.is-active { opacity: 1; }
  .hero-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(12,12,18,0.55) 0%, rgba(12,12,18,0.18) 30%, rgba(12,12,18,0.55) 66%, rgba(12,12,18,0.95) 100%),
      radial-gradient(120% 80% at 0% 100%, rgba(12,12,18,0.7) 0%, rgba(12,12,18,0) 55%);
  }
  .hero-content { position: relative; z-index: 2; padding-bottom: clamp(2.5rem, 7vw, 5rem); padding-top: 8rem; width: 100%; }
  .hero-eyebrow {
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.85); margin: 0 0 1.4rem; display: flex; align-items: center; gap: 0.8rem;
  }
  .hero-eyebrow::before { content: ""; width: 2.2rem; height: 2px; background: var(--color-laiton-clair); }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.6rem, 8vw, 6.4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin: 0 0 1.8rem;
    color: #fff;
    max-width: 16ch;
  }
  .hl-line { display: block; overflow: hidden; }
  .hl-line > span { display: block; transform: translateY(110%); animation: rise 1s var(--ease) forwards; }
  .hl-line:nth-child(1) > span { animation-delay: 0.1s; }
  .hl-line:nth-child(2) > span { animation-delay: 0.24s; }
  .hl-line:nth-child(3) > span { animation-delay: 0.38s; }
  @keyframes rise { to { transform: translateY(0); } }
  .hero-title .hl-accent {
    font-family: var(--font-italic);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.005em;
    color: #fff;
  }
  .hero-actions { gap: 1rem; animation: fade 1s var(--ease) 0.7s both; }
  @keyframes fade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  .hero-tab {
    position: absolute; top: calc(var(--header-height) + 1.4rem); right: clamp(1.2rem, 5vw, 3rem);
    z-index: 2; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em;
    color: #fff; border: 1px solid rgba(255,255,255,0.55); padding: 0.4rem 0.8rem;
  }
  .hero-legend {
    position: absolute; right: clamp(1.2rem, 5vw, 3rem); bottom: clamp(2.5rem, 7vw, 5rem);
    z-index: 2; text-align: right; display: flex; flex-direction: column; gap: 0.1rem;
  }
  .hl-place { font-weight: 700; font-size: 1rem; color: #fff; }
  .hl-meta { font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.78); }

  .hero-dots { position: absolute; left: 50%; transform: translateX(-50%); bottom: 1.4rem; z-index: 2; display: flex; gap: 0.5rem; }
  .hero-dot { width: 28px; height: 3px; border: none; cursor: pointer; background: rgba(255,255,255,0.4); transition: background 0.3s var(--ease); }
  .hero-dot.is-active { background: #fff; }

  .hero-scroll {
    position: absolute; left: clamp(1.2rem, 5vw, 3rem); bottom: 1.2rem; z-index: 2;
    display: flex; align-items: center; gap: 0.6rem; color: rgba(255,255,255,0.8);
    font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600;
  }
  .hero-scroll-line { width: 46px; height: 1px; background: rgba(255,255,255,0.5); position: relative; overflow: hidden; }
  .hero-scroll-line::after { content: ""; position: absolute; inset: 0; width: 40%; background: #fff; animation: scrollline 2s var(--ease) infinite; }
  @keyframes scrollline { 0% { transform: translateX(-100%); } 100% { transform: translateX(250%); } }
  @media (max-width: 640px) { .hero-scroll, .hero-legend { display: none; } }

  /* ========== MANIFESTE ========== */
  .manifeste { padding-block: clamp(3rem, 6vw, 5.5rem); }
  /* Bloc centré : le vide est réparti symétriquement, donc intentionnel.
     Un grand « 2006 » en filigrane ancre l'espace sans concurrencer le texte. */
  .manifeste-inner { position: relative; text-align: center; }
  .manifeste-inner .eyebrow { justify-content: center; position: relative; z-index: 1; }
  .manifeste-watermark {
    position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%);
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(9rem, 30vw, 26rem); line-height: 1; letter-spacing: -0.05em;
    color: var(--color-laiton); opacity: 0.045;
    z-index: 0; pointer-events: none; user-select: none; white-space: nowrap;
  }
  .manifeste-text {
    position: relative; z-index: 1;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.7rem, 4.2vw, 3.3rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-encre);
    max-width: 19ch;
    margin: 0.7rem auto 0;
    text-wrap: balance;
  }
  .manifeste-text strong { font-weight: 800; }
  .manifeste .hl-accent { font-family: var(--font-italic); font-style: italic; font-weight: 400; color: var(--color-laiton); }
  /* Filigrane masqué sur petit écran : un grand « 2006 » derrière le texte
     deviendrait vite brouillon — on garde le manifeste parfaitement lisible. */
  @media (max-width: 600px) {
    .manifeste-watermark { display: none; }
  }

  /* ========== PROCÉDÉ ========== */
  .procede-head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .timeline { list-style: none; margin: 0; padding: 0; }
  .tl-item { display: grid; grid-template-columns: 5.5rem 1fr; gap: clamp(1rem, 3vw, 2.5rem); padding: 2.2rem 0; border-top: 1px solid var(--color-border-strong); align-items: start; }
  .tl-item:last-child { border-bottom: 1px solid var(--color-border-strong); }
  .tl-num { font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 800; color: var(--color-laiton); line-height: 1; letter-spacing: -0.04em; }
  .tl-body { max-width: 56ch; }
  .tl-body h3 { margin-bottom: 0.4rem; }
  .tl-body p { margin: 0; color: var(--color-ink-soft); }

  /* ========== UNIVERS ========== */
  /* Gouttière entre le bord d'écran et le conteneur centré. */
  .univers { --edge: max(1.2rem, calc((100vw - var(--container)) / 2)); }
  .univers-head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .univers-list { display: grid; gap: clamp(3.5rem, 8vw, 7rem); }
  /* Deux moitiés pleine largeur : l'image atteint le bord d'écran côté extérieur,
     le texte reste aligné sur le conteneur via le padding --edge. */
  .univers-row { display: grid; grid-template-columns: 1fr 1fr; align-items: center; }
  .univers-row.is-reverse .univers-media { order: 2; }
  .univers-row.is-reverse .univers-body { order: 1; }
  .univers-media { display: block; overflow: hidden; aspect-ratio: 16 / 11; background: var(--color-encre); }
  .univers-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s var(--ease); }
  .univers-row:hover .univers-media img { transform: scale(1.04); }
  /* Texte : côté extérieur aligné au conteneur, côté intérieur respirant. */
  .univers-body { padding-left: clamp(1.8rem, 4vw, 3.5rem); padding-right: var(--edge); }
  .univers-row.is-reverse .univers-body { padding-left: var(--edge); padding-right: clamp(1.8rem, 4vw, 3.5rem); }
  .univers-sel { font-size: 0.74rem; font-weight: 700; letter-spacing: 0.16em; color: var(--color-laiton-fonce); display: block; margin-bottom: 1rem; }
  .univers-body h3 { font-size: clamp(1.7rem, 3vw, 2.4rem); margin-bottom: 0.8rem; }
  .univers-body p { color: var(--color-ink-soft); max-width: 46ch; margin-bottom: 1.4rem; font-size: 1.05rem; }
  @media (max-width: 860px) {
    .univers-row, .univers-row.is-reverse { grid-template-columns: 1fr; }
    .univers-row .univers-media, .univers-row.is-reverse .univers-media { order: 0; }
    .univers-row .univers-body, .univers-row.is-reverse .univers-body {
      order: 1;
      padding: 1.6rem var(--edge) 0;
    }
    .univers-media { aspect-ratio: 16 / 10; }
  }

  /* ========== APPROCHE ========== */
  .approche-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .approche-intro { position: sticky; top: calc(var(--header-height) + 2rem); }
  .approche-intro h2 { color: #fff; }
  .approche-intro .btn { margin-top: 1.4rem; }
  .atouts { margin: 0; display: grid; gap: 0; }
  .atout { padding: 1.7rem 0; border-top: 1px solid rgba(255,255,255,0.16); }
  .atout:last-child { border-bottom: 1px solid rgba(255,255,255,0.16); }
  .atout dt { display: flex; align-items: baseline; gap: 1rem; font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; letter-spacing: -0.01em; }
  .atout-num { font-size: 0.8rem; font-weight: 700; color: var(--color-laiton-clair); }
  .atout dd { margin: 0 0 0 2.8rem; color: #c2c2cc; }
  @media (max-width: 820px) { .approche-grid { grid-template-columns: 1fr; } .approche-intro { position: static; } .atout dd { margin-left: 0; } }

  /* ========== GALERIE PREVIEW ========== */
  .shortlist-head { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-end; gap: 1.5rem; margin-bottom: clamp(2.2rem, 4vw, 3.4rem); }
  .shortlist-head h2 { margin: 0; }
  .gp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  .gp-item { display: block; overflow: hidden; border-radius: var(--radius-img); aspect-ratio: 1 / 1; background: var(--color-encre); }
  .gp-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s var(--ease); }
  .gp-item:hover img { transform: scale(1.05); }
  @media (max-width: 640px) { .gp-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<script>
  const root = document.getElementById("hero-carousel");
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>(".hero-slide"));
    const placeEl = document.getElementById("hero-place");
    const metaEl = document.getElementById("hero-meta");
    const tabEl = document.getElementById("hero-tab");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;

    function go(n: number) {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => s.classList.toggle("is-active", k === i));
      const a = slides[i];
      if (placeEl && a.dataset.place) placeEl.textContent = a.dataset.place;
      if (metaEl && a.dataset.meta) metaEl.textContent = a.dataset.meta;
      if (tabEl && a.dataset.sel) tabEl.textContent = a.dataset.sel;
    }
    // Fondu très lent (8 s), sans puces ; figé si l'utilisateur réduit les animations.
    if (!reduce && slides.length > 1) setInterval(() => go(i + 1), 8000);
  }
</script>
