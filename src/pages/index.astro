---
import BaseLayout from "../layouts/BaseLayout.astro";
import LogoCloud from "../components/LogoCloud.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import GoogleReviews from "../components/GoogleReviews.astro";
import CTASection from "../components/CTASection.astro";
import { contact, site } from "../data/site";
import { events } from "../data/events";
import { caseStudies } from "../data/caseStudies";
import { testimonials } from "../data/testimonials";

const title =
  "Euro Events — Maison de curation événementielle à Paris | Sélection gratuite de prestataires";
const description = site.description;

const procede = [
  {
    n: "01",
    t: "Vous nous confiez votre projet",
    d: "Type d'événement, nombre de convives, dates, lieu pressenti, budget. En quelques minutes, par téléphone ou en ligne.",
  },
  {
    n: "02",
    t: "Notre experte compose la shortlist",
    d: "Elle recherche, compare et négocie à la main les lieux et prestataires qui servent vraiment vos objectifs.",
  },
  {
    n: "03",
    t: "Vous recevez votre sélection",
    d: "Une shortlist argumentée et des devis, sous 24 à 48 h. Vous choisissez ; nous vous accompagnons jusqu'au jour J.",
  },
];

const atouts = [
  ["Gratuit pour votre entreprise", "Aucun honoraire, aucune commission à votre charge. Notre rémunération vient des prestataires, jamais de vous."],
  ["Une interlocutrice, pas un standard", "La même experte du premier échange au jour J. Une relation, pas un ticket."],
  ["Une réponse sous 24-48 h", "Le temps d'une vraie curation — ni l'instantané d'un algorithme, ni l'attente d'un devis classique."],
  ["Votre budget tenu", "Nous partons de votre enveloppe et négocions pour vous. Pas de dépassement, pas de surprise."],
];

const featured = testimonials[0];

// Slides du carrousel hero (défilement auto 2,5 s).
const heroSlides = [
  {
    src: "/images/hero/1.jpg",
    alt: "Château de Chambord, lieu d'exception pour un événement d'entreprise",
    place: "Château de Chambord",
    meta: "Séminaire d'exception · Val de Loire",
  },
  {
    src: "/images/hero/2.jpg",
    alt: "Dîner de gala avec scénographie florale et mise en lumière dorée",
    place: "Dîner de gala",
    meta: "Scénographie sur mesure",
  },
  {
    src: "/images/hero/3.jpg",
    alt: "Lieu événementiel contemporain vitré avec scène et espace lounge",
    place: "Lieu événementiel contemporain",
    meta: "Convention & soirée",
  },
  {
    src: "/images/hero/4.jpg",
    alt: "Salle de réception dressée pour un dîner d'entreprise",
    place: "Banquet & réception",
    meta: "Dîner assis",
  },
];
---

<BaseLayout title={title} description={description} path="/">
  <!-- ====================== HERO ====================== -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">Maison de curation · Paris · depuis 2006</p>
        <h1 class="hero-title">
          <span class="line"><span>Une sélection</span></span>
          <span class="line"><span>faite à la main,</span></span>
          <span class="line line--accent"><span>pas par un moteur.</span></span>
        </h1>
        <p class="lead hero-lead">
          Depuis vingt ans, notre experte compose gratuitement la shortlist des lieux et
          prestataires de vos événements professionnels. Sélection humaine, tarifs négociés,
          un seul interlocuteur.
        </p>
        <div class="btn-row hero-cta">
          <a href="/devis/" class="btn btn--accent btn--lg">Demander ma sélection gratuite</a>
          <a href={`tel:${contact.phoneHref}`} class="hero-phone">
            <span class="hero-phone-label">ou parler à notre experte</span>
            <span class="hero-phone-num">{contact.phoneDisplay}</span>
          </a>
        </div>
      </div>

      <figure class="hero-figure">
        <div class="hero-frame" id="hero-carousel">
          {
            heroSlides.map((s, i) => (
              <img
                class:list={["hero-slide", { "is-active": i === 0 }]}
                src={s.src}
                alt={s.alt}
                width="640"
                height="800"
                data-place={s.place}
                data-meta={s.meta}
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : undefined}
              />
            ))
          }
          <img class="hero-logo-badge" src="/images/logo.png" alt="Euro Events" width="150" height="153" />
          {
            heroSlides.length > 1 && (
              <div class="hero-dots" role="tablist" aria-label="Photos">
                {heroSlides.map((_, i) => (
                  <button
                    type="button"
                    class:list={["hero-dot", { "is-active": i === 0 }]}
                    data-index={i}
                    aria-label={`Photo ${i + 1}`}
                  />
                ))}
              </div>
            )
          }
        </div>
        <figcaption class="hero-caption">
          <span class="hc-place">{heroSlides[0].place}</span>
          <span class="hc-meta">{heroSlides[0].meta}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <LogoCloud title="Une sélection éprouvée par les entreprises exigeantes" />

  <!-- ====================== PROCÉDÉ (timeline) ====================== -->
  <section class="section bg-white procede">
    <div class="container">
      <div class="procede-head">
        <p class="eyebrow">Le procédé</p>
        <h2>Trois temps, une seule interlocutrice.</h2>
      </div>
      <ol class="timeline">
        {
          procede.map((s) => (
            <li class="tl-item reveal">
              <span class="tl-num">{s.n}</span>
              <div class="tl-body">
                <h3>{s.t}</h3>
                <p>{s.d}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ====================== LA SHORTLIST (signature) ====================== -->
  <section class="section shortlist bg-ivory">
    <div class="container">
      <div class="shortlist-head">
        <div>
          <p class="eyebrow">La shortlist</p>
          <h2>Ce que nous composons<br />pour chaque type d'événement.</h2>
        </div>
        <p class="shortlist-intro lead">
          Une curation sur mesure — lieux, traiteurs, animations, transferts, scénographie —
          adaptée à vos objectifs et à votre budget.
        </p>
      </div>

      <div class="dossiers">
        {
          events.map((e, i) => (
            <a href={`/nos-evenements/${e.slug}/`} class="dossier reveal">
              <div class="dossier-media">
                <img src={e.image} alt={e.imageAlt} loading="lazy" decoding="async" />
                <span class="dossier-index">{String(i + 1).padStart(2, "0")}</span>
              </div>
              <div class="dossier-body">
                <h3>{e.title}</h3>
                <p>{e.cardTeaser}</p>
                <span class="link-arrow">Voir la sélection</span>
              </div>
            </a>
          ))
        }
        <a href="/nos-evenements/" class="dossier dossier--all reveal">
          <div class="dossier-all-inner">
            <span class="dossier-index">06</span>
            <h3>Un autre projet&nbsp;?</h3>
            <p>Mariage de formats, événement sur mesure — parlons-en.</p>
            <span class="link-arrow">Tout voir</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ====================== L'APPROCHE (liste éditoriale) ====================== -->
  <section class="section bg-navy approche">
    <div class="container approche-grid">
      <div class="approche-intro">
        <p class="eyebrow">Pourquoi nous</p>
        <h2>Une maison, pas une plateforme.</h2>
        <p class="lead">
          Nous ne renvoyons pas une liste générée. Nous engageons une personne, un goût,
          vingt ans de carnet d'adresses — au service d'un seul projet : le vôtre.
        </p>
        <a href="/notre-concept/" class="btn btn--outline">Notre façon de travailler</a>
      </div>
      <dl class="atouts">
        {
          atouts.map((a, i) => (
            <div class="atout reveal">
              <dt><span class="atout-num">{String(i + 1).padStart(2, "0")}</span>{a[0]}</dt>
              <dd>{a[1]}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- ====================== RÉFÉRENCES (dossier) ====================== -->
  <section class="section bg-white">
    <div class="container">
      <div class="shortlist-head">
        <div>
          <p class="eyebrow">Au dossier</p>
          <h2>Quelques événements signés Euro Events.</h2>
        </div>
        <a href="/references/" class="btn btn--outline refs-cta">Toutes les références</a>
      </div>
      <div class="grid grid-3">
        {caseStudies.map((study) => <CaseStudyCard study={study} />)}
      </div>
    </div>
  </section>

  <!-- ====================== TÉMOIGNAGE (citation éditoriale) ====================== -->
  <section class="section--tight bg-ivory">
    <div class="container container-narrow temoignage">
      <p class="eyebrow text-center">En confiance</p>
      <blockquote class="big-quote">{featured.quote}</blockquote>
      <p class="big-quote-cite">
        {featured.author} — {featured.role}, {featured.company}
      </p>
    </div>
  </section>

  <GoogleReviews />

  <CTASection />
</BaseLayout>

<style>
  /* ========== HERO ========== */
  .hero {
    background: var(--color-pierre);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(3rem, 7vw, 6.5rem);
  }
  .hero-title {
    font-size: clamp(2.7rem, 6.2vw, 5rem);
    line-height: 1.02;
    margin: 0 0 1.4rem;
    letter-spacing: -0.015em;
  }
  .hero-title .line { display: block; overflow: hidden; }
  .hero-title .line > span {
    display: block;
    transform: translateY(110%);
    animation: rise 0.95s var(--ease) forwards;
  }
  .hero-title .line:nth-child(1) > span { animation-delay: 0.05s; }
  .hero-title .line:nth-child(2) > span { animation-delay: 0.18s; }
  .hero-title .line:nth-child(3) > span { animation-delay: 0.31s; }
  .hero-title .line--accent > span {
    font-style: italic;
    font-weight: 500;
    color: var(--color-laiton-fonce);
  }
  @keyframes rise { to { transform: translateY(0); } }

  .hero-lead { max-width: 50ch; margin-bottom: 2rem; animation: fade 1s var(--ease) 0.5s both; }
  .hero-cta { gap: 1.6rem; animation: fade 1s var(--ease) 0.65s both; }
  @keyframes fade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  .hero-phone { display: flex; flex-direction: column; line-height: 1.3; }
  .hero-phone-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .hero-phone-num { font-weight: 600; font-size: 1.05rem; color: var(--color-encre); }
  .hero-phone:hover .hero-phone-num { color: var(--color-laiton-fonce); }

  /* Figure photo + légende dossier */
  .hero-figure { margin: 0; animation: fade 1.2s var(--ease) 0.2s both; }
  .hero-frame {
    position: relative;
    border-radius: var(--radius-img);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--color-prune);
    box-shadow: var(--shadow-lg);
  }
  /* Carrousel : slides empilées en fondu */
  .hero-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.9s var(--ease);
  }
  .hero-slide.is-active { opacity: 1; }

  /* Logo en haut à gauche, sur fond transparent */
  .hero-logo-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    height: 52px;
    width: auto;
    z-index: 3;
    filter: drop-shadow(0 1px 6px rgba(255, 255, 255, 0.55))
      drop-shadow(0 1px 2px rgba(255, 255, 255, 0.5));
  }

  /* Indicateurs */
  .hero-dots {
    position: absolute;
    bottom: 0.9rem;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    z-index: 3;
  }
  .hero-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: 0 1px 3px rgba(29, 27, 39, 0.4);
    transition: background 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .hero-dot.is-active { background: var(--color-laiton); transform: scale(1.25); }
  .hero-caption {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--color-laiton);
    margin-top: 0.9rem;
  }
  .hc-place { font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--color-encre); }
  .hc-meta { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-muted); }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-figure { max-width: 460px; }
  }

  /* ========== PROCÉDÉ (timeline) ========== */
  .procede-head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .tl-item {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: 2.2rem 0;
    border-top: 1px solid var(--color-border);
    align-items: start;
  }
  .tl-item:last-child { border-bottom: 1px solid var(--color-border); }
  .tl-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--color-laiton);
    line-height: 1;
  }
  .tl-body { max-width: 56ch; }
  .tl-body h3 { margin-bottom: 0.4rem; }
  .tl-body p { margin: 0; color: var(--color-ink-soft); }

  /* ========== SHORTLIST ========== */
  .shortlist-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
    margin-bottom: clamp(2.2rem, 4vw, 3.4rem);
  }
  .shortlist-head h2 { margin: 0; }
  .shortlist-intro { max-width: 38ch; margin: 0; }
  .refs-cta { flex-shrink: 0; }

  .dossiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .dossier {
    display: flex;
    flex-direction: column;
    background: var(--color-pierre);
    color: var(--color-encre);
    transition: background 0.4s var(--ease);
  }
  .dossier:hover { background: var(--color-calcaire); color: var(--color-encre); }
  .dossier-media { position: relative; aspect-ratio: 5 / 4; overflow: hidden; background: var(--color-prune); }
  .dossier-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s var(--ease); }
  .dossier:hover .dossier-media img { transform: scale(1.05); }
  .dossier-index {
    position: absolute;
    bottom: 0.7rem;
    left: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-blanc);
    text-shadow: 0 1px 6px rgba(34, 23, 51, 0.6);
  }
  .dossier-body { padding: 1.6rem 1.5rem 1.7rem; display: flex; flex-direction: column; flex: 1; }
  .dossier-body h3 { font-size: 1.35rem; margin-bottom: 0.5rem; }
  .dossier-body p { color: var(--color-ink-soft); flex: 1; margin-bottom: 1.1rem; font-size: 0.98rem; }

  .dossier--all {
    background-image: linear-gradient(rgba(29, 27, 39, 0.86), rgba(29, 27, 39, 0.92)),
      url("/images/autre-projet.jpg");
    background-size: cover;
    background-position: center;
    color: var(--color-blanc);
  }
  .dossier--all:hover {
    background-image: linear-gradient(rgba(29, 27, 39, 0.74), rgba(29, 27, 39, 0.84)),
      url("/images/autre-projet.jpg");
    color: var(--color-blanc);
  }
  .dossier-all-inner { padding: 1.8rem 1.6rem; display: flex; flex-direction: column; height: 100%; }
  .dossier--all .dossier-index { position: static; color: var(--color-laiton-clair); margin-bottom: auto; }
  .dossier--all h3 { color: var(--color-blanc); font-size: 1.35rem; margin: 1.2rem 0 0.5rem; }
  .dossier--all p { color: #c8bdd6; flex: 0; margin-bottom: 1.1rem; }
  .dossier--all .link-arrow { color: var(--color-laiton-clair); }

  @media (max-width: 900px) { .dossiers { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .dossiers { grid-template-columns: 1fr; } }

  /* ========== APPROCHE ========== */
  .approche-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .approche-intro { position: sticky; top: calc(var(--header-height) + 2rem); }
  .approche-intro h2 { color: var(--color-blanc); }
  .approche-intro .btn { margin-top: 1.4rem; }
  .atouts { margin: 0; display: grid; gap: 0; }
  .atout { padding: 1.7rem 0; border-top: 1px solid rgba(255, 255, 255, 0.16); }
  .atout:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.16); }
  .atout dt {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-blanc);
    margin-bottom: 0.5rem;
  }
  .atout-num { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-laiton-clair); letter-spacing: 0.1em; }
  .atout dd { margin: 0 0 0 2.8rem; color: #c8bdd6; }

  @media (max-width: 820px) {
    .approche-grid { grid-template-columns: 1fr; }
    .approche-intro { position: static; }
    .atout dd { margin-left: 0; }
  }

  /* ========== TÉMOIGNAGE ========== */
  .temoignage { text-align: center; }
  .big-quote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.2vw, 2.3rem);
    font-weight: 400;
    line-height: 1.32;
    color: var(--color-encre);
    margin: 0.5rem 0 1.4rem;
    text-wrap: balance;
  }
  .big-quote::before { content: "« "; color: var(--color-laiton); }
  .big-quote::after { content: " »"; color: var(--color-laiton); }
  .big-quote-cite {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }
</style>

<script>
  // Carrousel hero : défilement automatique toutes les 2,5 s.
  const root = document.getElementById("hero-carousel");
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>(".hero-dot"));
    const placeEl = document.querySelector<HTMLElement>(".hero-caption .hc-place");
    const metaEl = document.querySelector<HTMLElement>(".hero-caption .hc-meta");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    function go(n: number) {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => s.classList.toggle("is-active", k === i));
      dots.forEach((d, k) => d.classList.toggle("is-active", k === i));
      const a = slides[i];
      if (placeEl && a.dataset.place) placeEl.textContent = a.dataset.place;
      if (metaEl && a.dataset.meta) metaEl.textContent = a.dataset.meta;
    }
    function restart() {
      if (timer) clearInterval(timer);
      if (!reduce && slides.length > 1) timer = setInterval(() => go(i + 1), 2500);
    }
    dots.forEach((d) =>
      d.addEventListener("click", () => {
        go(Number(d.dataset.index));
        restart();
      })
    );
    restart();
  }
</script>
