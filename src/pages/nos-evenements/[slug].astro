---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTASection from "../../components/CTASection.astro";
import Testimonials from "../../components/Testimonials.astro";
import { events, type EventType } from "../../data/events";
import { contact, site } from "../../data/site";

export function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

interface Props {
  event: EventType;
}
const { event } = Astro.props as Props;
const path = `/nos-evenements/${event.slug}/`;

// Autres événements pour le maillage interne.
const others = events.filter((e) => e.slug !== event.slug);

// JSON-LD Service + BreadcrumbList
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: event.heading,
    serviceType: event.title,
    description: event.seoDescription,
    provider: { "@id": `${site.url}/#organization` },
    areaServed: "FR",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
      description: "Recherche de prestataires gratuite pour l'entreprise cliente",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: site.url + "/" },
      {
        "@type": "ListItem",
        position: 2,
        name: "Nos événements",
        item: site.url + "/nos-evenements/",
      },
      { "@type": "ListItem", position: 3, name: event.title, item: site.url + path },
    ],
  },
];
---

<BaseLayout title={event.seoTitle} description={event.seoDescription} path={path} jsonLd={jsonLd}>
  <Breadcrumbs
    items={[
      { label: "Nos événements", href: "/nos-evenements/" },
      { label: event.title },
    ]}
  />

  <!-- Hero événement -->
  <section class="ev-hero">
    <div class="container ev-hero-inner">
      <div class="ev-hero-content reveal">
        <p class="eyebrow">{event.icon} {event.title}</p>
        <h1>{event.heading}</h1>
        <p class="lead">{event.intro}</p>
        <div class="btn-row">
          <a href={`/devis/?type=${event.slug}`} class="btn btn--primary btn--lg">
            Demander un devis gratuit
          </a>
          <a href={`tel:${contact.phoneHref}`} class="btn btn--outline btn--lg">
            {contact.phoneDisplay}
          </a>
        </div>
      </div>
      <div class="ev-hero-media reveal">
        <img src={event.image} alt={event.imageAlt} width="600" height="420" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- Prestations -->
  <section class="section bg-white">
    <div class="container">
      <div class="section-head text-center reveal">
        <p class="eyebrow">Ce que nous trouvons pour vous</p>
        <h2>Tout ce dont votre {event.title.toLowerCase().replace(/s$/, "")} a besoin</h2>
        <p class="lead">
          Une recherche complète, gratuite et sur mesure — vous comparez, vous décidez.
        </p>
      </div>
      <div class="grid grid-3">
        {
          event.prestations.map((p) => (
            <article class="prestation reveal">
              <h3>{p.title}</h3>
              <p>{p.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Réassurance gratuité -->
  <section class="section--tight bg-cream">
    <div class="container">
      <div class="assurance reveal">
        <div class="assurance-item">
          <span class="icon-badge">💸</span>
          <div>
            <strong>100 % gratuit</strong>
            <span>Aucun frais pour votre entreprise</span>
          </div>
        </div>
        <div class="assurance-item">
          <span class="icon-badge">⚡</span>
          <div>
            <strong>24-48 h</strong>
            <span>Pour recevoir vos premières propositions</span>
          </div>
        </div>
        <div class="assurance-item">
          <span class="icon-badge">👤</span>
          <div>
            <strong>Interlocuteur unique</strong>
            <span>Une experte du brief au jour J</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini-cas -->
  <section class="section bg-white">
    <div class="container container-narrow">
      <div class="example-card reveal">
        <span class="example-tag">Exemple de réalisation</span>
        <h2>{event.example.title}</h2>
        <dl>
          <dt>Contexte</dt>
          <dd>{event.example.context}</dd>
          <dt>Notre solution</dt>
          <dd>{event.example.solution}</dd>
          <dt>Résultat</dt>
          <dd>{event.example.result}</dd>
        </dl>
        <p class="example-note">
          <small>Exemple représentatif — à remplacer par une étude de cas réelle validée.</small>
        </p>
      </div>
    </div>
  </section>

  <Testimonials limit={3} title="Ce qu'en disent nos clients" />

  <!-- Maillage interne : autres événements -->
  <section class="section--tight bg-cream">
    <div class="container">
      <div class="section-head reveal">
        <h2>Autres types d'événements</h2>
      </div>
      <div class="other-events">
        {
          others.map((e) => (
            <a href={`/nos-evenements/${e.slug}/`} class="other-chip">
              <span aria-hidden="true">{e.icon}</span> {e.title}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection title={`Prêt à organiser votre ${event.title.toLowerCase().replace(/s$/, "")} ?`} />
</BaseLayout>

<style>
  .ev-hero {
    background:
      radial-gradient(circle at 92% 0%, rgba(168, 119, 224, 0.5), transparent 45%),
      var(--color-ivory);
    border-bottom: 1px solid var(--color-border);
  }
  .ev-hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .ev-hero-media img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 10 / 7;
    object-fit: cover;
  }
  .ev-hero .lead {
    max-width: 56ch;
    margin-bottom: 1.6rem;
  }
  .prestation {
    padding: 1.5rem 1.5rem;
    border-radius: var(--radius-md);
    background: var(--color-ivory);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
  }
  .prestation h3 {
    font-size: 1.18rem;
    margin-bottom: 0.4rem;
  }
  .prestation p {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.98rem;
  }
  .assurance {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .assurance-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .assurance-item .icon-badge {
    margin-bottom: 0;
    flex-shrink: 0;
  }
  .assurance-item strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-primary-dark);
  }
  .assurance-item span {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }
  .example-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: clamp(1.6rem, 3vw, 2.5rem);
  }
  .example-tag {
    display: inline-block;
    background: var(--color-amber-200);
    color: var(--color-accent-dark);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.35rem 0.8rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1rem;
  }
  .example-card dl {
    margin: 1.2rem 0 0;
    display: grid;
    gap: 0.3rem;
  }
  .example-card dt {
    font-weight: 700;
    color: var(--color-accent-dark);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.8rem;
  }
  .example-card dd {
    margin: 0;
    color: var(--color-ink-soft);
  }
  .example-note {
    margin: 1.2rem 0 0;
    color: var(--color-muted);
  }
  .other-events {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
  .other-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.7rem 1.2rem;
    font-weight: 600;
    color: var(--color-primary-dark);
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .other-chip:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: var(--color-accent-dark);
  }
  @media (max-width: 880px) {
    .ev-hero-inner {
      grid-template-columns: 1fr;
    }
    .ev-hero-media {
      order: -1;
    }
    .assurance {
      grid-template-columns: 1fr;
    }
  }
</style>
