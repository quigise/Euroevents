---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Gallery from "../components/Gallery.astro";
import CTASection from "../components/CTASection.astro";

const title = "Galerie photos | Lieux & événements — Euro Events";
const description =
  "Parcourez notre galerie : lieux d'exception, séminaires, conventions et soirées d'entreprise organisés grâce à Euro Events. Trouvons ensemble le cadre idéal pour votre événement.";

const categories = [
  { key: "lieux", label: "Lieux" },
  { key: "seminaires", label: "Séminaires & conventions" },
  { key: "soirees", label: "Soirées & gala" },
  { key: "teambuilding", label: "Team building" },
];

const images = [
  { src: "/images/hero/1.jpg", alt: "Château de Chambord, lieu d'exception", caption: "Château de Chambord · Val de Loire", category: "lieux" },
  { src: "/images/events/soiree.jpg", alt: "Dîner de gala d'entreprise", caption: "Dîner de gala", category: "soirees" },
  { src: "/images/events/convention.jpg", alt: "Convention en auditorium avec conférencier", caption: "Convention plénière", category: "seminaires" },
  { src: "/images/gallery/reception.jpg", alt: "Réception privée avec tables dressées", caption: "Réception privée", category: "soirees" },
  { src: "/images/events/teambuilding.jpg", alt: "Team building outdoor sur l'eau", caption: "Team building outdoor", category: "teambuilding" },
  { src: "/images/gallery/sommet.jpg", alt: "Grande conférence sur scène devant le public", caption: "Sommet & grande conférence", category: "seminaires" },
  { src: "/images/events/reunion.jpg", alt: "Salle de réunion moderne et lumineuse", caption: "Journée d'étude", category: "seminaires" },
  { src: "/images/gallery/seminaire-qa.jpg", alt: "Séminaire d'entreprise, échanges avec la salle", caption: "Séminaire d'entreprise", category: "seminaires" },
  { src: "/images/autre-projet.jpg", alt: "Soirée cocktail élégante", caption: "Soirée cocktail", category: "soirees" },
  { src: "/images/hero/3.jpg", alt: "Lieu événementiel contemporain", caption: "Lieu contemporain", category: "lieux" },
  { src: "/images/hero/4.jpg", alt: "Salle de réception dressée", caption: "Banquet & réception", category: "soirees" },
  { src: "/images/hero/2.jpg", alt: "Scénographie florale dorée", caption: "Scénographie de gala", category: "soirees" },
];
---

<BaseLayout title={title} description={description} path="/galerie/">
  <Breadcrumbs items={[{ label: "Galerie" }]} />
  <PageHero
    eyebrow="Galerie photos"
    title="Des lieux et des moments d'exception"
    subtitle="Un aperçu des lieux et événements que nous trouvons et coordonnons pour les entreprises. Cliquez sur une image pour l'agrandir."
  />

  <section class="section bg-white">
    <div class="container">
      <Gallery images={images} categories={categories} />
    </div>
  </section>

  <CTASection title="Un lieu vous fait envie ? Parlons-en." />
</BaseLayout>

<style>
  .gallery-note {
    text-align: center;
    color: var(--color-muted);
    margin-bottom: 2rem;
    background: var(--color-cream);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.8rem 1.2rem;
  }
</style>
