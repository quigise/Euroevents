---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Gallery from "../components/Gallery.astro";
import CTASection from "../components/CTASection.astro";

const title = "Galerie photos | Lieux & événements — Euro Events";
const description =
  "Parcourez notre galerie : lieux d'exception, séminaires, conventions et soirées d'entreprise organisés grâce à Euro Events. Trouvons ensemble le cadre idéal pour votre événement.";

// ⚠️ PLACEHOLDERS : remplacer par les vraies photos fournies par le client.
const images = [
  { src: "/images/gallery/g1.svg", alt: "Séminaire au Château de Féré", caption: "Château de Féré · Picardie" },
  { src: "/images/gallery/g2.svg", alt: "Soirée au Molitor à Paris", caption: "Le Molitor · Paris" },
  { src: "/images/gallery/g3.svg", alt: "Plénière de convention avec scène", caption: "Convention plénière" },
  { src: "/images/gallery/g4.svg", alt: "Team building au Domaine de la Voisine", caption: "Domaine de la Voisine" },
  { src: "/images/gallery/g5.svg", alt: "Cocktail dînatoire d'entreprise", caption: "Cocktail dînatoire" },
  { src: "/images/gallery/g6.svg", alt: "Séminaire en lieu Châteauform'", caption: "Châteauform' · Paris" },
  { src: "/images/gallery/g7.svg", alt: "Salle de réunion équipée", caption: "Journée d'étude" },
  { src: "/images/gallery/g8.svg", alt: "Scénographie et mise en lumière d'un événement", caption: "Scénographie" },
  { src: "/images/gallery/g9.svg", alt: "Rooftop parisien privatisé pour une soirée", caption: "Rooftop parisien · Paris" },
];
---

<BaseLayout title={title} description={description} path="/galerie/">
  <Breadcrumbs items={[{ label: "Galerie" }]} />
  <PageHero
    eyebrow="Galerie photos"
    title="Des lieux et des moments d'exception"
    subtitle="Un aperçu des lieux et événements que nous trouvons et coordonnons pour les entreprises. Cliquez sur une image pour l'agrandir."
  />

  <section class="section bg-white">
    <div class="container">
      <p class="gallery-note reveal">
        <span class="note-tag">Note</span> Galerie illustrative — les visuels définitifs
        (photos réelles de lieux et d'événements) seront intégrés prochainement.
      </p>
      <Gallery images={images} />
    </div>
  </section>

  <CTASection title="Un lieu vous fait envie ? Parlons-en." />
</BaseLayout>

<style>
  .gallery-note {
    text-align: center;
    color: var(--color-muted);
    margin-bottom: 2rem;
    background: var(--color-cream);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.8rem 1.2rem;
  }
</style>
