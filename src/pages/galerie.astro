---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Gallery from "../components/Gallery.astro";
import CTASection from "../components/CTASection.astro";

const title = "Galerie photos | Lieux & événements — Euro Events";
const description =
  "Parcourez notre galerie : lieux d'exception, séminaires, conventions et soirées d'entreprise organisés grâce à Euro Events. Trouvons ensemble le cadre idéal pour votre événement.";

const images = [
  { src: "/images/hero.jpg", alt: "Château de Chambord, lieu d'exception", caption: "Château de Chambord · Val de Loire" },
  { src: "/images/events/soiree.jpg", alt: "Dîner de gala d'entreprise", caption: "Dîner de gala" },
  { src: "/images/events/convention.jpg", alt: "Convention en auditorium avec conférencier", caption: "Convention plénière" },
  { src: "/images/gallery/reception.jpg", alt: "Réception privée avec tables dressées", caption: "Réception privée" },
  { src: "/images/events/teambuilding.jpg", alt: "Team building outdoor sur l'eau", caption: "Team building outdoor" },
  { src: "/images/gallery/sommet.jpg", alt: "Grande conférence sur scène devant le public", caption: "Sommet & grande conférence" },
  { src: "/images/events/reunion.jpg", alt: "Salle de réunion moderne et lumineuse", caption: "Journée d'étude" },
  { src: "/images/gallery/seminaire-qa.jpg", alt: "Séminaire d'entreprise, échanges avec la salle", caption: "Séminaire d'entreprise" },
  { src: "/images/autre-projet.jpg", alt: "Soirée cocktail élégante", caption: "Soirée cocktail" },
];
---

<BaseLayout title={title} description={description} path="/galerie/">
  <Breadcrumbs items={[{ label: "Galerie" }]} />
  <PageHero
    eyebrow="Galerie photos"
    title="Des lieux et des moments d'exception"
    subtitle="Un aperçu des lieux et événements que nous trouvons et coordonnons pour les entreprises. Cliquez sur une image pour l'agrandir."
  />

  <section class="section bg-white">
    <div class="container">
      <Gallery images={images} />
    </div>
  </section>

  <CTASection title="Un lieu vous fait envie ? Parlons-en." />
</BaseLayout>

<style>
  .gallery-note {
    text-align: center;
    color: var(--color-muted);
    margin-bottom: 2rem;
    background: var(--color-cream);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.8rem 1.2rem;
  }
</style>
