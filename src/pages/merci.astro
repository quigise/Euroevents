---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contact } from "../data/site";

const title = "Merci pour votre demande | Euro Events";
const description = "Votre demande a bien été envoyée. Notre experte vous recontacte sous 24-48 h.";
---

<BaseLayout title={title} description={description} path="/merci/" noindex>
  <section class="thanks">
    <div class="container container-narrow text-center">
      <div class="thanks-check" aria-hidden="true">✓</div>
      <h1>Merci, votre demande est bien envoyée&nbsp;!</h1>
      <p class="lead">
        Notre experte événementielle étudie votre besoin et revient vers vous
        <strong>sous 24 à 48 h</strong> avec une première sélection de prestataires.
      </p>
      <p>
        Une question entre-temps ? Appelez-nous au
        <a href={`tel:${contact.phoneHref}`}>{contact.phoneDisplay}</a>
        — {contact.hours.toLowerCase()}.
      </p>
      <div class="btn-row btn-row--center">
        <a href="/" class="btn btn--primary">Retour à l'accueil</a>
        <a href="/nos-evenements/" class="btn btn--outline">Découvrir nos événements</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks {
    padding-block: clamp(4rem, 10vw, 7rem);
    background:
      radial-gradient(circle at 50% 0%, rgba(168, 119, 224, 0.4), transparent 50%),
      var(--color-ivory);
  }
  .thanks-check {
    width: 86px;
    height: 86px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.6rem;
    color: #fff;
    background: linear-gradient(135deg, var(--color-accent), var(--color-amber-400));
    border-radius: 50%;
    box-shadow: var(--shadow-lg);
  }
  .thanks .btn-row {
    margin-top: 2rem;
  }
</style>
