---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  cta?: boolean;
}
import { contact } from "../data/site";
const { eyebrow, title, subtitle, cta = false } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {subtitle && <p class="lead">{subtitle}</p>}
      {
        cta && (
          <div class="btn-row">
            <a href="/devis/" class="btn btn--accent">Demander ma sélection gratuite</a>
            <a href={`tel:${contact.phoneHref}`} class="btn btn--outline">
              {contact.phoneDisplay}
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .page-hero {
    background: var(--color-blanc);
    padding-block: clamp(2.8rem, 6vw, 4.8rem) clamp(2.2rem, 4vw, 3.2rem);
    border-bottom: 1px solid var(--color-border);
  }
  .page-hero-inner {
    max-width: 56rem;
    border-left: 2px solid var(--color-laiton);
    padding-left: clamp(1.2rem, 3vw, 2.2rem);
  }
  .page-hero h1 { margin-bottom: 0.5rem; }
  .page-hero .lead { max-width: 60ch; }
  .page-hero .btn-row { margin-top: 1.8rem; }
</style>
