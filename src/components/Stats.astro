---
import { stats as defaultStats } from "../data/site";
export interface Props {
  items?: { value: string; label: string }[];
}
const { items = defaultStats } = Astro.props;
---

<section class="section--tight bg-navy stats">
  <div class="container">
    <ul class="stats-grid">
      {
        items.map((s) => (
          <li class="stat reveal">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .stats-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.5rem clamp(1rem, 3vw, 2rem);
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }
  .stat:first-child { border-left: none; }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 700;
    color: var(--color-blanc);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-laiton-clair);
  }
  @media (max-width: 680px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem 0; }
    .stat:nth-child(3) { border-left: none; }
  }
</style>
