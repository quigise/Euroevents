---
export interface Props {
  title?: string;
  eyebrow?: string;
}
const {
  title = "Une maison, pas une plateforme.",
  eyebrow = "Pourquoi nous",
} = Astro.props;

const benefits = [
  ["Gratuit pour votre entreprise", "Aucun honoraire, aucune commission à votre charge. Notre rémunération vient des prestataires, jamais de vous."],
  ["Une interlocutrice, pas un standard", "La même experte du premier échange au jour J. Une relation, pas un ticket."],
  ["Une réponse sous 24-48 h", "Le temps d'une vraie curation, sans l'attente d'un devis classique."],
  ["Votre budget tenu", "Nous partons de votre enveloppe et négocions pour vous. Pas de dépassement, pas de surprise."],
  ["Des prestataires éprouvés", "Un carnet d'adresses construit sur vingt ans, sélectionné à la main."],
  ["Un vrai gain de temps", "Fini les dizaines d'appels et de devis : nous cherchons à votre place."],
];
---

<section class="section bg-white">
  <div class="container">
    <div class="benefits-head">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
    </div>
    <dl class="benefits-list">
      {
        benefits.map((b, i) => (
          <div class="benefit reveal">
            <dt><span class="benefit-num">{String(i + 1).padStart(2, "0")}</span>{b[0]}</dt>
            <dd>{b[1]}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .benefits-head { max-width: 640px; margin-bottom: clamp(2.2rem, 4vw, 3.2rem); }
  .benefits-list {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0 clamp(2rem, 5vw, 4rem);
  }
  .benefit { padding: 1.7rem 0; border-top: 1px solid var(--color-border); }
  .benefit dt {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-encre);
    margin-bottom: 0.5rem;
  }
  .benefit-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--color-laiton-fonce);
  }
  .benefit dd { margin: 0 0 0 2.8rem; color: var(--color-ink-soft); }
  @media (max-width: 760px) {
    .benefits-list { grid-template-columns: 1fr; }
    .benefit dd { margin-left: 0; }
  }
</style>
