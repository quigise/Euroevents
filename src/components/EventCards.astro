---
import { events } from "../data/events";
export interface Props {
  title?: string;
  eyebrow?: string;
  showIntro?: boolean;
}
const {
  title = "Quel est votre type d'événement ?",
  eyebrow = "Nos domaines d'expertise",
  showIntro = true,
} = Astro.props;
---

<section class="section bg-cream">
  <div class="container">
    <div class="section-head text-center reveal">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      {
        showIntro && (
          <p class="lead">
            Quel que soit votre projet, nous trouvons gratuitement les prestataires
            qu'il vous faut.
          </p>
        )
      }
    </div>
    <div class="grid grid-3 event-grid">
      {
        events.map((e) => (
          <a href={`/nos-evenements/${e.slug}/`} class="card event-card reveal">
            <span class="event-icon icon-badge">{e.icon}</span>
            <h3>{e.title}</h3>
            <p>{e.cardTeaser}</p>
            <span class="link-arrow">En savoir plus</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    padding: 1.9rem 1.7rem;
    color: var(--color-ink);
  }
  .event-card:hover {
    color: var(--color-ink);
  }
  .event-card h3 {
    margin-bottom: 0.5rem;
  }
  .event-card p {
    color: var(--color-ink-soft);
    flex: 1;
    margin-bottom: 1.1rem;
  }
</style>
