---
/**
 * Logo Euro Events.
 * ⚠️ PLACEHOLDER : logo typographique provisoire.
 * En V1, remplacer par le logo officiel fourni par le client
 * (déposer /public/images/logo.svg puis remplacer ce bloc par <img src="/images/logo.svg" … />).
 */
export interface Props {
  variant?: "default" | "light";
}
const { variant = "default" } = Astro.props;
const main = variant === "light" ? "#ffffff" : "var(--color-navy-900)";
const accent = "var(--color-amber-500)";
---

<span class="logo" data-variant={variant}>
  <svg
    width="40"
    height="40"
    viewBox="0 0 40 40"
    fill="none"
    aria-hidden="true"
    focusable="false"
  >
    <circle cx="20" cy="20" r="19" stroke={accent} stroke-width="2" />
    <path
      d="M13 13h13v3.4h-9v3.1h8v3.3h-8v3.2h9.3V29H13z"
      fill={main}
    />
    <circle cx="20" cy="20" r="2.2" fill={accent} />
  </svg>
  <span class="logo-text" style={`--logo-main:${main}`}>
    <span class="logo-name">Euro Events</span>
    <span class="logo-sub">Agence événementielle</span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .logo-name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.28rem;
    color: var(--logo-main);
    letter-spacing: -0.01em;
  }
  .logo-sub {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-amber-600);
    font-weight: 600;
  }
  .logo[data-variant="light"] .logo-sub {
    color: var(--color-amber-400);
  }
  @media (max-width: 420px) {
    .logo-sub {
      display: none;
    }
  }
</style>
