---
/**
 * Logo Euro Events (sans le slogan « moteur de recherche », retiré pour cohérence
 * avec le positionnement « curation humaine »). Version blanche pour fond sombre.
 */
export interface Props {
  variant?: "default" | "light";
}
const { variant = "default" } = Astro.props;
const src = variant === "light" ? "/images/logo-noslogan-white.png" : "/images/logo-noslogan.png";
---

<span class:list={["logo", `logo--${variant}`]}>
  <img src={src} alt="Euro Events" width="150" height="145" decoding="async" />
</span>

<style>
  .logo { display: inline-flex; align-items: center; }
  .logo img { width: auto; height: 60px; }
  .logo--light img { height: 64px; }
</style>
