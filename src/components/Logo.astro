---
/**
 * Logo Euro Events — reconstitution vectorielle d'après le logo officiel fourni :
 * marque faite de bandes chevron ascendantes en dégradé violet (profond → lavande),
 * mot « EURO EVENTS » + slogan « Le moteur de recherche de tous vos événements ».
 *
 * ℹ️ Si le fichier vectoriel officiel est fourni, le déposer dans /public/images/logo.svg
 * et remplacer le bloc <svg> ci-dessous par <img src="/images/logo.svg" … />.
 */
export interface Props {
  variant?: "default" | "light";
}
const { variant = "default" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--color-ink)";
const sloganColor = variant === "light" ? "var(--color-violet-200)" : "var(--color-violet-600)";
---

<span class="logo" data-variant={variant}>
  <svg
    class="logo-mark"
    width="46"
    height="42"
    viewBox="0 0 48 44"
    fill="none"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <linearGradient id="ee-grad" x1="0" y1="44" x2="48" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#2c1a57" />
        <stop offset="0.55" stop-color="#5b43a0" />
        <stop offset="1" stop-color="#a877e0" />
      </linearGradient>
    </defs>
    <!-- Bande basse (la plus profonde) -->
    <path
      d="M4 30 L30 30 L38 35 L30 40 L4 40 L10 35 Z"
      fill="#3a2474"
    />
    <!-- Bande médiane -->
    <path
      d="M8 17 L34 17 L42 22 L34 27 L8 27 L14 22 Z"
      fill="#5b43a0"
    />
    <!-- Bande haute (la plus claire) -->
    <path
      d="M12 4 L38 4 L46 9 L38 14 L12 14 L18 9 Z"
      fill="#9d82d6"
    />
    <!-- Voile dégradé unifiant les trois bandes -->
    <path
      d="M4 30 L30 30 L38 35 L30 40 L4 40 L10 35 Z M8 17 L34 17 L42 22 L34 27 L8 27 L14 22 Z M12 4 L38 4 L46 9 L38 14 L12 14 L18 9 Z"
      fill="url(#ee-grad)"
      opacity="0.35"
    />
  </svg>
  <span class="logo-text">
    <span class="logo-name" style={`color:${wordColor}`}>EURO EVENTS</span>
    <span class="logo-slogan" style={`color:${sloganColor}`}>
      Le moteur de recherche de vos événements
    </span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .logo-mark {
    flex-shrink: 0;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .logo-name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.18rem;
    letter-spacing: 0.06em;
  }
  .logo-slogan {
    font-size: 0.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
    margin-top: 0.12rem;
  }
  @media (max-width: 460px) {
    .logo-slogan {
      display: none;
    }
  }
</style>
