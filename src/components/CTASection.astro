---
import { contact } from "../data/site";
export interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Confiez-nous votre prochain événement.",
  text = "Décrivez votre projet : notre experte vous renvoie une shortlist de lieux et prestataires, et des devis, sous 24 à 48 h. Gratuit, sans engagement.",
} = Astro.props;
---

<section class="section cta-band bg-navy">
  <div class="container cta-inner">
    <div class="cta-text">
      <p class="eyebrow">Sans engagement · 100 % gratuit</p>
      <h2>{title}</h2>
    </div>
    <div class="cta-action">
      <p class="lead">{text}</p>
      <div class="btn-row">
        <a href="/devis/" class="btn btn--accent btn--lg">Demander ma sélection gratuite</a>
        <a href={`tel:${contact.phoneHref}`} class="btn btn--outline btn--lg">
          {contact.phoneDisplay}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band { border-top: 3px solid var(--color-laiton); }
  .cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .cta-text h2 { color: var(--color-blanc); font-size: clamp(2rem, 4vw, 3.2rem); margin: 0; }
  .cta-action .lead { margin-bottom: 1.8rem; }
  @media (max-width: 820px) {
    .cta-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
