---
import { contact } from "../data/site";
export interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Parlez-nous de votre projet d'événement",
  text = "Recevez gratuitement une sélection de prestataires et des devis adaptés à votre budget, sous 24 à 48 h. Sans engagement.",
} = Astro.props;
---

<section class="section bg-navy cta-band">
  <div class="container text-center reveal">
    <p class="eyebrow">Service 100 % gratuit · Sans engagement</p>
    <h2>{title}</h2>
    <p class="lead cta-text">{text}</p>
    <div class="btn-row btn-row--center">
      <a href="/devis/" class="btn btn--primary btn--lg">Demander un devis gratuit</a>
      <a href={`tel:${contact.phoneHref}`} class="btn btn--outline btn--lg">
        Appeler le {contact.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background-image: radial-gradient(
        circle at 15% 20%,
        rgba(168, 119, 224, 0.28),
        transparent 45%
      ),
      radial-gradient(circle at 85% 80%, rgba(91, 67, 160, 0.45), transparent 50%);
  }
  .cta-text {
    max-width: 56ch;
    margin-inline: auto;
    margin-bottom: 2rem;
  }
</style>
