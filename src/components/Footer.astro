---
import { mainNav, contact, social, site } from "../data/site";
import { events } from "../data/events";
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <Logo variant="light" />
        <p class="footer-tagline">{site.tagline}</p>
        <div class="footer-social" aria-label="Réseaux sociaux">
          <a href={social.facebook} aria-label="Facebook" rel="noopener" target="_blank">Facebook</a>
          <a href={social.linkedin} aria-label="LinkedIn" rel="noopener" target="_blank">LinkedIn</a>
          <a href={social.instagram} aria-label="Instagram" rel="noopener" target="_blank">Instagram</a>
        </div>
      </div>

      <div class="footer-col">
        <h2 class="footer-title">Navigation</h2>
        <ul>
          {mainNav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href="/devis/">Demander ma sélection</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-title">Événements</h2>
        <ul>
          {events.map((e) => <li><a href={`/nos-evenements/${e.slug}/`}>{e.title}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-title">L'agence</h2>
        <address class="footer-contact">
          <p>{contact.addressStreet}<br />{contact.addressZip} {contact.addressCity}</p>
          <p>
            <a href={`tel:${contact.phoneHref}`}>{contact.phoneDisplay}</a><br />
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
          </p>
          <p class="footer-hours">{contact.hours}</p>
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {site.legalName} · Maison de curation événementielle</p>
      <ul class="footer-legal">
        <li><a href="/mentions-legales/">Mentions légales</a></li>
        <li><a href="/politique-confidentialite/">Confidentialité</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-encre);
    color: #c4b9d2;
    padding-block: clamp(3.5rem, 6vw, 5rem) 1.8rem;
    border-top: 3px solid var(--color-laiton);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.2fr;
    gap: clamp(1.8rem, 4vw, 3rem);
    padding-bottom: 2.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .footer-tagline { margin-top: 1.2rem; color: #a99cb8; font-size: 0.96rem; max-width: 34ch; }
  .footer-social { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.3rem; }
  .footer-social a {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-laiton-clair);
  }
  .footer-social a:hover { color: var(--color-blanc); }
  .footer-title {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-laiton-clair);
    margin-bottom: 1.2rem;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .footer-col a, .footer-contact a { color: #c4b9d2; font-size: 0.96rem; }
  .footer-col a:hover, .footer-contact a:hover { color: var(--color-blanc); }
  .footer-contact { font-style: normal; color: #c4b9d2; font-size: 0.96rem; }
  .footer-contact p { margin-bottom: 0.8rem; }
  .footer-hours { color: #8f84a0; font-size: 0.9rem; }
  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.6rem;
    color: #8f84a0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }
  .footer-legal { display: flex; gap: 1.4rem; list-style: none; margin: 0; padding: 0; }
  .footer-legal a { color: #8f84a0; }
  .footer-legal a:hover { color: var(--color-blanc); }
  @media (max-width: 860px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
