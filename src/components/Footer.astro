---
import { mainNav, contact, social, site } from "../data/site";
import { events } from "../data/events";
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <p class="footer-claim">
        Une maison de curation humaine.<br />
        Lieux et prestataires choisis à la main, depuis 2006.
      </p>
      <a href="/devis/" class="btn btn--accent btn--lg footer-cta">Demander ma sélection gratuite</a>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <Logo variant="light" />
        <p class="footer-tagline">{site.tagline}</p>
        <div class="footer-social" aria-label="Réseaux sociaux">
          <a href={social.facebook} aria-label="Euro Events sur Facebook" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M14 9h2.5l.5-3H14V4.5c0-.9.3-1.5 1.6-1.5H17V.3C16.7.2 15.8 0 14.8 0 12.5 0 11 1.4 11 4v2H8.5v3H11v8h3V9z"/></svg>
          </a>
          <a href={social.linkedin} aria-label="Euro Events sur LinkedIn" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5.001A2.5 2.5 0 014.98 3.5zM3 9h4v12H3V9zm6 0h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05 4.02 0 4.76 2.65 4.76 6.1V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.07 1.4-2.07 2.85V21H9V9z"/></svg>
          </a>
          <a href={social.instagram} aria-label="Euro Events sur Instagram" rel="noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 2c2.7 0 3 0 4.1.06 1.1.05 1.8.24 2.5.51.7.27 1.3.64 1.9 1.23.59.59.96 1.18 1.23 1.9.27.66.46 1.4.5 2.5.06 1.1.07 1.4.07 4.1s0 3-.06 4.1c-.05 1.1-.24 1.8-.51 2.5a5.2 5.2 0 01-1.23 1.9c-.59.59-1.18.96-1.9 1.23-.66.27-1.4.46-2.5.5-1.1.06-1.4.07-4.1.07s-3 0-4.1-.06c-1.1-.05-1.8-.24-2.5-.51a5.2 5.2 0 01-1.9-1.23 5.2 5.2 0 01-1.23-1.9c-.27-.66-.46-1.4-.5-2.5C2.01 15 2 14.7 2 12s0-3 .06-4.1c.05-1.1.24-1.8.51-2.5.27-.7.64-1.3 1.23-1.9.59-.59 1.18-.96 1.9-1.23.66-.27 1.4-.46 2.5-.5C9 2.01 9.3 2 12 2zm0 1.8c-2.67 0-2.99.01-4.04.06-.97.04-1.5.21-1.85.35-.47.18-.8.4-1.15.75-.35.35-.57.68-.75 1.15-.14.35-.31.88-.35 1.85-.05 1.05-.06 1.37-.06 4.04s.01 2.99.06 4.04c.04.97.21 1.5.35 1.85.18.47.4.8.75 1.15.35.35.68.57 1.15.75.35.14.88.31 1.85.35 1.05.05 1.37.06 4.04.06s2.99-.01 4.04-.06c.97-.04 1.5-.21 1.85-.35.47-.18.8-.4 1.15-.75.35-.35.57-.68.75-1.15.14-.35.31-.88.35-1.85.05-1.05.06-1.37.06-4.04s-.01-2.99-.06-4.04c-.04-.97-.21-1.5-.35-1.85a3.1 3.1 0 00-.75-1.15 3.1 3.1 0 00-1.15-.75c-.35-.14-.88-.31-1.85-.35-1.05-.05-1.37-.06-4.04-.06zm0 3.06a5.14 5.14 0 110 10.28 5.14 5.14 0 010-10.28zm0 1.8a3.34 3.34 0 100 6.68 3.34 3.34 0 000-6.68zm5.34-3.2a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h2 class="footer-title">Navigation</h2>
        <ul>
          {mainNav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href="/devis/">Demander ma sélection</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-title">Événements</h2>
        <ul>
          {events.map((e) => <li><a href={`/nos-evenements/${e.slug}/`}>{e.title}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-title">L'agence</h2>
        <address class="footer-contact">
          <p>{contact.addressStreet}<br />{contact.addressZip} {contact.addressCity}</p>
          <p>
            <a href={`tel:${contact.phoneHref}`}>{contact.phoneDisplay}</a><br />
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
          </p>
          <p class="footer-hours">{contact.hours}</p>
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {site.legalName} · Maison de curation événementielle</p>
      <ul class="footer-legal">
        <li><a href="/mentions-legales/">Mentions légales</a></li>
        <li><a href="/politique-confidentialite/">Confidentialité</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-encre);
    color: #c3c7d0;
    padding-block: clamp(3.5rem, 6vw, 5rem) 1.8rem;
    border-top: 3px solid var(--color-laiton);
  }
  /* Bandeau de marque + dernier CTA primaire */
  .footer-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem 2.5rem;
    padding-bottom: clamp(2.4rem, 4vw, 3.4rem);
    margin-bottom: clamp(2.4rem, 4vw, 3.4rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .footer-claim {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-blanc);
    max-width: 22ch;
  }
  .footer-cta { flex-shrink: 0; }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.2fr;
    gap: clamp(1.8rem, 4vw, 3rem);
    padding-bottom: 2.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .footer-tagline { margin-top: 1.2rem; color: #9aa0ab; font-size: 0.96rem; max-width: 34ch; }
  .footer-social { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.3rem; }
  .footer-social a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18); color: #aeb3bf;
    transition: background-color 0.2s var(--ease), color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .footer-social svg { width: 18px; height: 18px; fill: currentColor; }
  .footer-social a:hover { background: var(--color-laiton); border-color: var(--color-laiton); color: var(--color-blanc); }
  .footer-title {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #aeb3bf;
    margin-bottom: 1.2rem;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .footer-col a, .footer-contact a { color: #c3c7d0; font-size: 0.96rem; }
  .footer-col a:hover, .footer-contact a:hover { color: var(--color-blanc); }
  .footer-contact { font-style: normal; color: #c3c7d0; font-size: 0.96rem; }
  .footer-contact p { margin-bottom: 0.8rem; }
  .footer-hours { color: #7e8490; font-size: 0.9rem; }
  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.6rem;
    color: #7e8490;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }
  .footer-legal { display: flex; gap: 1.4rem; list-style: none; margin: 0; padding: 0; }
  .footer-legal a { color: #7e8490; }
  .footer-legal a:hover { color: var(--color-blanc); }
  @media (max-width: 860px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
