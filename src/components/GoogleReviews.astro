---
/**
 * Avis Google — bande compacte : note moyenne + lien vers la fiche Google.
 * (Les témoignages développés vivent dans la section Témoignages, pour éviter le doublon.)
 * Note réelle issue de la fiche Google de l'agence (juin 2026).
 */
import { googleReviewsUrl, googleRating } from "../data/site";
const rating = googleRating.value.toLocaleString("fr-FR", { minimumFractionDigits: 1 });
const reviewCount = googleRating.count;
---

<section class="section--tight google-band">
  <div class="container gb-inner">
    <div class="gb-score">
      <span class="gb-value">{rating}<span class="gb-out">/5</span></span>
      <div class="gb-right">
        <span class="gb-stars" aria-label={`${rating} sur 5`}>★★★★★</span>
        <span class="gb-label">
          <span class="g-mark" aria-hidden="true">G</span> {reviewCount} avis Google
        </span>
      </div>
    </div>
    <div class="gb-cta">
      <a href={googleReviewsUrl} target="_blank" rel="noopener" class="btn btn--outline">
        Voir nos {reviewCount} avis Google
      </a>
    </div>
  </div>
</section>

<style>
  .google-band { background: var(--color-calcaire); border-block: 1px solid var(--color-border); }
  .gb-inner {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1.5rem 2.5rem;
  }
  .gb-score { display: flex; align-items: center; gap: 1.4rem; }
  .gb-value {
    font-family: var(--font-display); font-weight: 800; font-size: clamp(2.6rem, 6vw, 4rem);
    line-height: 1; letter-spacing: -0.04em; color: var(--color-encre);
  }
  .gb-out { font-size: 0.4em; color: var(--color-muted); font-weight: 700; margin-left: 0.1em; }
  .gb-right { display: flex; flex-direction: column; gap: 0.3rem; }
  .gb-stars { color: #f5a623; font-size: 1.25rem; letter-spacing: 2px; }
  .gb-label { display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 0.95rem; color: var(--color-ink-soft); }
  .g-mark {
    display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px;
    border-radius: 50%; background: #fff; border: 1px solid var(--color-border);
    font-family: var(--font-display); font-weight: 800; color: #4285f4; font-size: 0.8rem;
  }
  .gb-cta { display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  @media (max-width: 600px) { .gb-cta { align-items: stretch; } }
</style>
