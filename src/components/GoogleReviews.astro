---
/**
 * Section Avis Google.
 * Lien réel vers la fiche Google de l'agence ; les textes d'avis et la note
 * chiffrée sont des PLACEHOLDERS à remplacer par les avis réels (ou un widget).
 * Aucune donnée structurée AggregateRating n'est émise tant que la note n'est
 * pas vérifiable (on évite un faux balisage SEO).
 */
import { googleReviewsUrl } from "../data/site";

const reviews = [
  {
    name: "Responsable événementiel",
    text: "Réactivité et professionnalisme. Une sélection de lieux parfaite pour notre séminaire, et tout cela gratuitement.",
  },
  {
    name: "Office Manager",
    text: "Un accompagnement de A à Z, des prestataires de qualité et un budget tenu. Je recommande vivement.",
  },
  {
    name: "Assistante de direction",
    text: "Gain de temps énorme. Une vraie experte à l'écoute, pas une plateforme impersonnelle.",
  },
];
---

<section class="section bg-cream">
  <div class="container">
    <div class="gr-head">
      <div>
        <p class="eyebrow">Avis Google</p>
        <h2>Ce qu'en disent nos clients.</h2>
      </div>
      <a href={googleReviewsUrl} target="_blank" rel="noopener" class="btn btn--outline gr-cta">
        Voir tous nos avis Google
      </a>
    </div>

    <div class="gr-grid">
      {
        reviews.map((r) => (
          <figure class="gr-card reveal">
            <span class="gr-stars" aria-label="5 étoiles sur 5">★★★★★</span>
            <blockquote>{r.text}</blockquote>
            <figcaption>{r.name}</figcaption>
          </figure>
        ))
      }
    </div>
    <p class="gr-note">
      <span class="note-tag">Note</span> Avis illustratifs — à remplacer par les avis Google réels
      (ou un widget). La note moyenne sera affichée une fois confirmée.
    </p>
  </div>
</section>

<style>
  .gr-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .gr-head h2 { margin: 0; }
  .gr-cta { flex-shrink: 0; }
  .gr-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .gr-card {
    background: var(--color-blanc);
    padding: 2rem 1.8rem;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .gr-stars { color: var(--color-laiton); letter-spacing: 2px; margin-bottom: 1rem; }
  .gr-card blockquote {
    margin: 0 0 1.2rem;
    font-size: 1.05rem;
    color: var(--color-ink);
    flex: 1;
  }
  .gr-card figcaption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .gr-note { margin-top: 1.5rem; color: var(--color-muted); }
</style>
