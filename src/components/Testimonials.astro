---
import { testimonials } from "../data/testimonials";
export interface Props {
  limit?: number;
  title?: string;
  eyebrow?: string;
}
const {
  limit = testimonials.length,
  title = "En confiance",
  eyebrow = "Témoignages",
} = Astro.props;
const items = testimonials.slice(0, limit);
---

<section class="section bg-cream">
  <div class="container">
    <div class="t-head reveal">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
    </div>
    <div class="t-grid">
      {
        items.map((t) => (
          <figure class="t-card reveal">
            <span class="t-stars" aria-label={`${t.rating} sur 5`}>{"★".repeat(t.rating)}</span>
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="t-author">{t.author}</span>
              <span class="t-role">{t.source} · {t.when}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .t-head { max-width: 640px; margin-bottom: clamp(2.2rem, 4vw, 3.2rem); }
  .t-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .t-card {
    background: var(--color-blanc);
    padding: 2.2rem 1.9rem;
    display: flex;
    flex-direction: column;
  }
  .t-stars { color: #f5a623; font-size: 1rem; letter-spacing: 2px; margin-bottom: 1rem; }
  .t-card blockquote {
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--color-encre);
    margin: 0 0 1.6rem;
    flex: 1;
  }
  .t-card blockquote::before { content: "« "; color: var(--color-laiton); }
  .t-card blockquote::after { content: " »"; color: var(--color-laiton); }
  figcaption { display: flex; flex-direction: column; gap: 0.15rem; }
  .t-author { font-weight: 600; color: var(--color-encre); }
  .t-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
</style>
