---
import type { CaseStudy } from "../data/caseStudies";
export interface Props {
  study: CaseStudy;
  detailed?: boolean;
  sel?: string;
}
const { study, detailed = false, sel } = Astro.props;
---

<article class="case reveal">
  <div class="case-media">
    <img src={study.image} alt={study.imageAlt} loading="lazy" decoding="async" />
    {sel && <span class="case-sel">{sel}</span>}
  </div>
  <div class="case-meta">
    {study.year && <span class="case-year">{study.year}</span>}
    <span>{study.eventType}</span>
    <span class="case-dot">·</span>
    <span>{study.participants}</span>
  </div>
  <h3>{study.title}</h3>
  {
    detailed ? (
      <dl class="case-detail">
        <div>
          <dt>Contexte</dt>
          <dd>{study.context}</dd>
        </div>
        <div>
          <dt>Notre sélection</dt>
          <dd>{study.solution}</dd>
        </div>
        <div>
          <dt>Résultat</dt>
          <dd>{study.result}</dd>
        </div>
      </dl>
    ) : (
      <p class="case-teaser">{study.context}</p>
    )
  }
</article>

<style>
  .case { display: flex; flex-direction: column; }
  .case-media {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    border-radius: var(--radius-img);
    background: var(--color-prune);
    margin-bottom: 1.1rem;
  }
  .case-media { position: relative; }
  .case-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s var(--ease); }
  .case:hover .case-media img { transform: scale(1.04); }
  .case-sel {
    position: absolute; top: 0.8rem; left: 0.8rem;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.14em; color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.6); padding: 0.3rem 0.6rem;
    text-shadow: 0 1px 4px rgba(12, 12, 18, 0.5);
  }
  .case-year { color: var(--color-encre); font-weight: 700; }
  .case-meta {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-laiton-fonce);
    margin-bottom: 0.5rem;
  }
  .case-dot { color: var(--color-mauve); }
  .case h3 { font-size: 1.35rem; margin-bottom: 0.6rem; }
  .case-teaser { color: var(--color-ink-soft); margin: 0; }
  .case-detail { margin: 0; display: grid; gap: 0.9rem; padding-top: 0.4rem; }
  .case-detail dt {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-laiton-fonce);
    margin-bottom: 0.2rem;
  }
  .case-detail dd { margin: 0; color: var(--color-ink-soft); }
</style>
