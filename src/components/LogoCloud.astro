---
import { clientLogos } from "../data/site";
export interface Props {
  title?: string;
  variant?: "light" | "dark";
}
const { title = "Ils nous font confiance", variant = "light" } = Astro.props;
---

<section class:list={["logo-cloud", `logo-cloud--${variant}`]}>
  <div class="container">
    <p class="logo-cloud-title">{title}</p>
    <ul class="logo-list">
      {
        clientLogos.map((c) =>
          c.logo ? (
            <li class="logo-item logo-item--img">
              <img src={c.logo} alt={c.name} loading="lazy" decoding="async" />
            </li>
          ) : (
            <li class="logo-item">{c.name}</li>
          )
        )
      }
    </ul>
  </div>
</section>

<style>
  .logo-cloud {
    padding-block: clamp(2.5rem, 5vw, 3.5rem);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .logo-cloud--light { background: var(--color-pierre); }
  .logo-cloud--dark { background: var(--color-encre); }
  .logo-cloud-title {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-laiton-fonce);
    margin-bottom: 1.8rem;
  }
  .logo-cloud--dark .logo-cloud-title { color: var(--color-laiton-clair); }
  .logo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(1.2rem, 3vw, 2.4rem);
  }
  .logo-item {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    letter-spacing: 0.01em;
    color: var(--color-encre);
    opacity: 0.82;
    transition: opacity 0.3s var(--ease), color 0.3s var(--ease);
    white-space: nowrap;
  }
  .logo-item:not(.logo-item--img):not(:last-child)::after {
    content: "·";
    margin-left: clamp(1.2rem, 3vw, 2.4rem);
    color: var(--color-laiton);
    opacity: 0.7;
  }
  .logo-item:hover { opacity: 1; color: var(--color-laiton-fonce); }
  .logo-cloud--dark .logo-item { color: var(--color-blanc); }

  /* Vrais logos (images) : tuiles uniformes (les visuels ont leur propre fond) */
  .logo-item--img {
    opacity: 1;
    background: var(--color-blanc);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.7rem 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: clamp(72px, 8vw, 92px);
    width: clamp(150px, 18vw, 190px);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .logo-item--img:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .logo-item--img img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    object-fit: contain;
    border-radius: 3px;
  }
</style>
