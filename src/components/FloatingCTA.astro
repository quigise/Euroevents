---
import { contact } from "../data/site";
---

<div class="floating-cta">
  <a href={`tel:${contact.phoneHref}`} class="fab fab--phone" aria-label={`Appeler Euro Events au ${contact.phoneDisplay}`}>
    <span class="fab-ico" aria-hidden="true">☏</span>
    <span class="fab-label">Appeler</span>
  </a>
  <a href="/devis/" class="fab fab--quote" aria-label="Demander ma sélection gratuite">
    <span class="fab-label">Ma sélection gratuite</span>
  </a>
</div>

<style>
  .floating-cta {
    position: fixed;
    right: clamp(0.8rem, 2vw, 1.4rem);
    bottom: clamp(0.8rem, 2vw, 1.4rem);
    z-index: 90;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .fab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.3rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.92rem;
    letter-spacing: 0.01em;
    box-shadow: var(--shadow-md);
    transition: transform 0.25s var(--ease), background 0.25s var(--ease), color 0.25s var(--ease);
  }
  .fab--quote { background: var(--color-laiton); color: var(--color-encre); }
  .fab--quote:hover { background: var(--color-encre); color: var(--color-blanc); transform: translateY(-2px); }
  .fab--phone { background: var(--color-encre); color: var(--color-blanc); }
  .fab--phone:hover { background: var(--color-prune); color: var(--color-blanc); transform: translateY(-2px); }
  .fab-ico { font-size: 1.1rem; }

  @media (max-width: 600px) {
    .floating-cta { flex-direction: row; left: 0.8rem; right: 0.8rem; }
    .fab { flex: 1; justify-content: center; }
  }
</style>
