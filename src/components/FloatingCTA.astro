---
import { contact } from "../data/site";
---

<a
  href={`tel:${contact.phoneHref}`}
  class="phone-fab"
  aria-label={`Appeler Euro Events au ${contact.phoneDisplay}`}
>
  <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" fill="none">
    <path
      d="M6.6 10.8a15.3 15.3 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24c1.1.37 2.3.57 3.5.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.2.2 2.4.57 3.5a1 1 0 0 1-.25 1l-2.2 2.3z"
      fill="currentColor"
    />
  </svg>
</a>

<style>
  .phone-fab {
    display: none; /* masqué par défaut (desktop) */
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 90;
    width: 56px;
    height: 56px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-laiton);
    color: #fff;
    box-shadow: 0 10px 26px -8px rgba(95, 75, 158, 0.7);
    transition: transform 0.2s var(--ease), background 0.2s var(--ease);
  }
  .phone-fab:hover { color: #fff; }
  .phone-fab:active { transform: scale(0.94); }

  /* Affichée uniquement sur mobile/petits écrans */
  @media (max-width: 768px) {
    .phone-fab { display: inline-flex; }
  }
</style>
