---
import { mainNav, contact } from "../data/site";
import { events } from "../data/events";

export interface Props {
  /** Header transparent par-dessus un hero plein cadre (accueil). */
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class:list={["site-header", { "is-transparent": transparent }]} id="site-header">
  <div class="container header-inner">
    <a href="/" class="header-logo" aria-label="Euro Events — accueil">
      <img class="logo-dark" src="/images/logo.png" alt="Euro Events" width="150" height="153" />
      <img class="logo-light" src="/images/logo-white.png" alt="Euro Events" width="150" height="153" aria-hidden="true" />
    </a>

    <nav class="header-nav" aria-label="Navigation principale">
      <ul>
        <li><a href="/notre-concept/" class:list={["nav-link", { "is-active": isActive("/notre-concept/") }]}>Concept</a></li>
        <li class="has-sub">
          <a href="/nos-evenements/" class:list={["nav-link", { "is-active": isActive("/nos-evenements/") }]} aria-haspopup="true">
            Événements <span class="caret" aria-hidden="true">▾</span>
          </a>
          <div class="submenu">
            <a href="/nos-evenements/">Tous nos événements</a>
            {events.map((e) => <a href={`/nos-evenements/${e.slug}/`}>{e.title}</a>)}
          </div>
        </li>
        <li><a href="/references/" class:list={["nav-link", { "is-active": isActive("/references/") }]}>Références</a></li>
        <li><a href="/partenaires/" class:list={["nav-link", { "is-active": isActive("/partenaires/") }]}>Partenaires</a></li>
        <li><a href="/a-propos/" class:list={["nav-link", { "is-active": isActive("/a-propos/") }]}>À propos</a></li>
        <li><a href="/galerie/" class:list={["nav-link", { "is-active": isActive("/galerie/") }]}>Galerie</a></li>
        <li><a href="/contact/" class:list={["nav-link", { "is-active": isActive("/contact/") }]}>Contact</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <a href={`tel:${contact.phoneHref}`} class="header-phone">{contact.phoneDisplay}</a>
      <a href="/devis/" class="btn btn--accent header-cta">Ma sélection gratuite</a>
      <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <nav aria-label="Navigation mobile">
      <ul>
        {
          mainNav.filter((i) => i.href !== "/").map((item, idx) => (
            <li>
              <a href={item.href} class:list={["mobile-link", { "is-active": isActive(item.href) }]}>
                <span class="mobile-index">{String(idx + 1).padStart(2, "0")}</span>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="mobile-nav-actions">
      <a href="/devis/" class="btn btn--accent btn--block">Demander ma sélection gratuite</a>
      <a href={`tel:${contact.phoneHref}`} class="btn btn--outline btn--block">{contact.phoneDisplay}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .site-header.is-scrolled { box-shadow: 0 1px 0 var(--color-border), 0 10px 30px -20px rgba(0,0,0,0.3); }

  /* --- Variante transparente (accueil, par-dessus le hero) --- */
  .site-header.is-transparent {
    position: absolute;
    left: 0; right: 0; top: 0;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }
  .site-header.is-transparent.is-scrolled {
    position: fixed;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom-color: var(--color-border);
  }

  .header-inner { display: flex; align-items: center; gap: 1.5rem; height: var(--header-height); }
  .header-logo { display: inline-flex; align-items: center; flex-shrink: 0; position: relative; }
  .header-logo img { height: 52px; width: auto; transition: opacity 0.3s var(--ease); }
  .logo-light { position: absolute; left: 0; top: 50%; transform: translateY(-50%); opacity: 0; }
  /* Sur header transparent non scrollé : logo blanc */
  .is-transparent:not(.is-scrolled) .logo-dark { opacity: 0; }
  .is-transparent:not(.is-scrolled) .logo-light { opacity: 1; }

  .header-nav { margin-left: auto; }
  .header-nav ul { display: flex; gap: 1.5rem; list-style: none; margin: 0; padding: 0; align-items: center; }
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-ink-soft);
  }
  .nav-link::after {
    content: ""; position: absolute; left: 0; bottom: -2px; width: 0; height: 2px;
    background: var(--color-laiton); transition: width 0.3s var(--ease);
  }
  .nav-link:hover, .nav-link.is-active { color: var(--color-encre); }
  .nav-link:hover::after, .nav-link.is-active::after { width: 100%; }
  .caret { font-size: 0.6rem; }

  /* Sous-menu Événements */
  .has-sub { position: relative; }
  .submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 250px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: 0.5rem;
    display: grid;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .has-sub:hover .submenu, .has-sub:focus-within .submenu {
    opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0);
  }
  .submenu a {
    padding: 0.6rem 0.8rem; font-size: 0.92rem; font-weight: 500; color: var(--color-ink-soft);
    border-radius: var(--radius-sm);
  }
  .submenu a:hover { background: var(--color-calcaire); color: var(--color-encre); }

  .header-actions { display: flex; align-items: center; gap: 1.2rem; flex-shrink: 0; }
  .header-phone { font-size: 0.88rem; font-weight: 600; color: var(--color-encre); white-space: nowrap; }
  .header-phone:hover { color: var(--color-laiton-fonce); }
  .header-cta { padding: 0.7rem 1.2rem; font-size: 0.88rem; }

  /* Couleurs claires sur header transparent */
  .is-transparent:not(.is-scrolled) .nav-link,
  .is-transparent:not(.is-scrolled) .header-phone { color: rgba(255, 255, 255, 0.92); }
  .is-transparent:not(.is-scrolled) .nav-link:hover,
  .is-transparent:not(.is-scrolled) .nav-link.is-active { color: #fff; }
  .is-transparent:not(.is-scrolled) .nav-toggle { border-color: rgba(255,255,255,0.5); }
  .is-transparent:not(.is-scrolled) .nav-toggle span { background: #fff; }

  .nav-toggle {
    display: none; flex-direction: column; justify-content: center; gap: 5px;
    width: 44px; height: 44px; padding: 0 10px; background: transparent;
    border: 1px solid var(--color-border-strong); border-radius: var(--radius-sm); cursor: pointer;
  }
  .nav-toggle span { display: block; height: 1.5px; width: 100%; background: var(--color-encre); transition: transform 0.25s var(--ease), opacity 0.25s var(--ease); }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-nav { border-top: 1px solid var(--color-border); background: #fff; padding: 1.2rem clamp(1.2rem, 5vw, 3rem) 1.8rem; }
  .mobile-nav ul { list-style: none; margin: 0 0 1.2rem; padding: 0; }
  .mobile-link {
    display: flex; align-items: baseline; gap: 0.9rem; padding: 0.85rem 0.2rem;
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 800; letter-spacing: -0.02em;
    color: var(--color-encre); border-bottom: 1px solid var(--color-border);
  }
  .mobile-index { font-size: 0.72rem; font-weight: 700; color: var(--color-laiton-fonce); }
  .mobile-link.is-active { color: var(--color-laiton-fonce); }
  .mobile-nav-actions { display: grid; gap: 0.8rem; }

  @media (max-width: 1080px) {
    .header-nav, .header-phone { display: none; }
    .nav-toggle { display: flex; }
    .header-actions { margin-left: auto; }
    /* Sur header transparent mobile, le menu déroulant a fond blanc : garder le toggle visible */
  }
  @media (max-width: 560px) { .header-cta { display: none; } }
</style>

<script>
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 40);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    toggle.setAttribute("aria-label", open ? "Ouvrir le menu" : "Fermer le menu");
    if (mobileNav) mobileNav.hidden = open;
    // Sur mobile, forcer le header en mode solide quand le menu est ouvert
    header?.classList.toggle("is-scrolled", !open || window.scrollY > 40);
  });
  mobileNav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      if (mobileNav) mobileNav.hidden = true;
    })
  );
</script>
