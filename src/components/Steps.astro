---
export interface Props {
  title?: string;
  eyebrow?: string;
}
const {
  title = "Trois temps, une seule interlocutrice.",
  eyebrow = "Le procédé",
} = Astro.props;

const steps = [
  {
    n: "01",
    title: "Vous nous confiez votre projet",
    text: "Type d'événement, nombre de convives, dates, lieu pressenti, budget. En quelques minutes, par téléphone ou en ligne.",
  },
  {
    n: "02",
    title: "Notre experte compose la shortlist",
    text: "Elle recherche, compare et négocie à la main les lieux et prestataires qui servent vraiment vos objectifs.",
  },
  {
    n: "03",
    title: "Vous recevez votre sélection",
    text: "Une shortlist argumentée et des devis, sous 24 à 48 h. Vous choisissez ; nous vous accompagnons jusqu'au jour J.",
  },
];
---

<section class="section bg-white">
  <div class="container">
    <div class="steps-head">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
    </div>
    <ol class="timeline">
      {
        steps.map((s) => (
          <li class="tl-item reveal">
            <span class="tl-num">{s.n}</span>
            <div class="tl-body">
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .steps-head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .timeline { list-style: none; margin: 0; padding: 0; }
  .tl-item {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: 2.2rem 0;
    border-top: 1px solid var(--color-border);
    align-items: start;
  }
  .tl-item:last-child { border-bottom: 1px solid var(--color-border); }
  .tl-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--color-laiton);
    line-height: 1;
  }
  .tl-body { max-width: 56ch; }
  .tl-body h3 { margin-bottom: 0.4rem; }
  .tl-body p { margin: 0; color: var(--color-ink-soft); }
</style>
