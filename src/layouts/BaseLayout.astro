---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingCTA from "../components/FloatingCTA.astro";
import { site, contact, social } from "../data/site";

export interface Props {
  title: string;
  description: string;
  /** Chemin relatif de la page (ex. "/contact/") pour l'URL canonique. */
  path?: string;
  /** Image Open Graph (chemin absolu depuis /public). */
  ogImage?: string;
  /** Injecter du JSON-LD supplémentaire (Service, BreadcrumbList…). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Désactiver l'indexation (pages utilitaires type "merci"). */
  noindex?: boolean;
}

const {
  title,
  description,
  path = "",
  ogImage = "/images/og-default.svg",
  jsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(path || Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(ogImage, site.url).href;

// Données structurées Organisation / LocalBusiness présentes sur toutes les pages.
const organizationLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.url}/#organization`,
  name: site.legalName,
  alternateName: site.name,
  url: site.url,
  description: site.description,
  foundingDate: String(site.foundedYear),
  telephone: `+${contact.phoneHref.replace(/\D/g, "")}`,
  email: contact.email,
  priceRange: "Gratuit pour l'entreprise cliente",
  areaServed: "FR",
  address: {
    "@type": "PostalAddress",
    streetAddress: contact.addressStreet,
    postalCode: contact.addressZip,
    addressLocality: contact.addressCity,
    addressCountry: "FR",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: contact.geo.lat,
    longitude: contact.geo.lng,
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "08:00",
    closes: "20:00",
  },
  sameAs: [social.facebook, social.linkedin, social.instagram],
};

const jsonLdArray = [organizationLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#2c1a57" />

    <!-- Polices Google : préconnexion + chargement non bloquant -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Outfit:wght@300;400;500;600;700&display=swap"
    />

    <!-- Données structurées -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdArray)}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Aller au contenu</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingCTA />

    <!-- Révélation discrète au scroll (IntersectionObserver, respecte prefers-reduced-motion) -->
    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
